{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-gauntlet.local/contracts/dashboard_data.schema.json",
  "title": "Agent Gauntlet Dashboard Data",
  "type": "object",
  "required": ["overview", "harnesses", "scenarios", "traceEvents", "candidatePatches", "coverage", "promotionReport"],
  "properties": {
    "overview": {
      "type": "object",
      "required": ["product", "tagline", "currentHarness", "readinessScore", "readinessFormula", "passRate", "criticalFailures", "apiRegressions", "testWeakeningAttempts", "regressionTestsAdded"],
      "properties": {
        "product": { "type": "string" },
        "tagline": { "type": "string" },
        "currentHarness": { "type": "string" },
        "readinessScore": { "type": "number" },
        "readinessFormula": { "type": "string" },
        "passRate": { "type": "string" },
        "criticalFailures": { "type": "integer" },
        "apiRegressions": { "type": "integer" },
        "testWeakeningAttempts": { "type": "integer" },
        "regressionTestsAdded": { "type": "integer" }
      }
    },
    "harnesses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "readinessScore", "readinessInputs", "passRate", "criticalFailures", "apiRegressions", "testWeakeningAttempts", "prematureFinalAnswers"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "readinessScore": { "type": "number" },
          "readinessInputs": {
            "type": "object",
            "required": ["passRate", "criticalSafetyScore", "validationEvidenceScore", "minimalDiffScore", "costStabilityScore"],
            "properties": {
              "passRate": { "type": "number" },
              "criticalSafetyScore": { "type": "number" },
              "validationEvidenceScore": { "type": "number" },
              "minimalDiffScore": { "type": "number" },
              "costStabilityScore": { "type": "number" }
            }
          },
          "passRate": { "type": "string" },
          "criticalFailures": { "type": "integer" },
          "apiRegressions": { "type": "integer" },
          "testWeakeningAttempts": { "type": "integer" },
          "prematureFinalAnswers": { "type": "integer" }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "split", "v1", "v2"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "split": { "type": "string" },
          "v1": { "type": "string" },
          "v2": { "type": "string" }
        }
      }
    },
    "traceEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenarioId", "step", "eventType", "summary", "severity", "evaluatorEvidence"],
        "properties": {
          "scenarioId": { "type": "string" },
          "step": { "type": "integer" },
          "eventType": { "type": "string" },
          "filePath": { "type": "string" },
          "summary": { "type": "string" },
          "severity": { "type": "string" },
          "flags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evaluatorEvidence": { "type": "string" }
        }
      }
    },
    "candidatePatches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "baseHarnessVersion", "candidateHarnessVersion", "patchType", "status", "validationScore", "reason", "gateResults"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "baseHarnessVersion": { "type": "string" },
          "candidateHarnessVersion": { "type": "string" },
          "patchType": { "type": "string" },
          "status": { "type": "string" },
          "validationScore": { "type": "number" },
          "reason": { "type": "string" },
          "diffSummary": { "type": "array", "items": { "type": "string" } },
          "gateResults": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["gate", "passed", "evidence"],
              "properties": {
                "gate": { "type": "string" },
                "passed": { "type": "boolean" },
                "evidence": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "coverage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk", "guardrail", "validator", "status"],
        "properties": {
          "risk": { "type": "string" },
          "guardrail": { "type": "string" },
          "validator": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    },
    "promotionReport": {
      "type": "object",
      "required": ["promotedCandidate", "promotedHarnessVersion", "promotionGate", "whyPromoted", "remainingGaps"],
      "properties": {
        "promotedCandidate": { "type": "string" },
        "promotedHarnessVersion": { "type": "string" },
        "promotionGate": {
          "type": "object",
          "required": [
            "validation_score_improves_by_at_least",
            "critical_failures_do_not_increase",
            "public_api_regressions",
            "test_deletion_failures",
            "test_weakening_failures",
            "protected_file_violations",
            "happy_path_regressions",
            "cost_increase_below",
            "changed_file_count_below"
          ],
          "properties": {
            "validation_score_improves_by_at_least": { "type": "number" },
            "critical_failures_do_not_increase": { "type": "boolean" },
            "public_api_regressions": { "type": "integer" },
            "test_deletion_failures": { "type": "integer" },
            "test_weakening_failures": { "type": "integer" },
            "protected_file_violations": { "type": "integer" },
            "happy_path_regressions": { "type": "integer" },
            "cost_increase_below": { "type": "number" },
            "changed_file_count_below": { "type": "integer" }
          }
        },
        "whyPromoted": { "type": "array", "items": { "type": "string" } },
        "remainingGaps": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}

