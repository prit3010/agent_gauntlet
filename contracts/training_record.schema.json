{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-gauntlet.local/contracts/training_record.schema.json",
  "title": "Agent Gauntlet Training Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "trainingId",
    "createdAt",
    "llm",
    "request",
    "baseHarnessVersion",
    "candidates",
    "status"
  ],
  "properties": {
    "trainingId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "llm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model", "liveCall"],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "liveCall": {
          "type": "boolean"
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidates"],
      "properties": {
        "candidates": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "baseHarnessVersion": {
      "type": "string",
      "minLength": 1
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status",
          "validationScore",
          "baseHarnessVersion",
          "candidateHarnessVersion",
          "patchType",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "validationScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "baseHarnessVersion": {
            "type": "string",
            "minLength": 1
          },
          "candidateHarnessVersion": {
            "type": "string",
            "minLength": 1
          },
          "patchType": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["fixture_backed_interface"]
    }
  }
}
