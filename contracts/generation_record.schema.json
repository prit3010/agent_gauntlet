{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-gauntlet.local/contracts/generation_record.schema.json",
  "title": "Agent Gauntlet Generation Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generationId",
    "createdAt",
    "llm",
    "pack",
    "request",
    "scenarioContract",
    "fixtureScenarios",
    "status"
  ],
  "properties": {
    "generationId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "llm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model", "liveCall"],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "liveCall": {
          "type": "boolean"
        }
      }
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenarios"],
      "properties": {
        "scenarios": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "scenarioContract": {
      "type": "string",
      "minLength": 1
    },
    "fixtureScenarios": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": ["fixture_backed_interface"]
    }
  }
}
