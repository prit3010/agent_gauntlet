{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-gauntlet.local/contracts/generation_record.schema.json",
  "title": "Agent Gauntlet Generation Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generationId",
    "metaRunId",
    "createdAt",
    "llm",
    "pack",
    "request",
    "scenarioContract",
    "fixtureScenarios",
    "generatedScenarios",
    "status"
  ],
  "properties": {
    "generationId": {
      "type": "string",
      "minLength": 1
    },
    "metaRunId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "llm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model", "requestedProvider", "requestedModel", "liveCall"],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "requestedProvider": {
          "type": "string",
          "minLength": 1
        },
        "requestedModel": {
          "type": "string",
          "minLength": 1
        },
        "liveCall": {
          "type": "boolean"
        },
        "sandbox": {
          "type": "string",
          "enum": ["read_only"]
        },
        "fallbackReason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenarios"],
      "properties": {
        "scenarios": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "scenarioContract": {
      "type": "string",
      "minLength": 1
    },
    "fixtureScenarios": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "generatedScenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "task",
          "invariant",
          "evidence",
          "passCriteria",
          "regressionCheck"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "task": {
            "type": "string",
            "minLength": 1
          },
          "invariant": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "passCriteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "regressionCheck": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["fixture_backed_interface", "codex_generated"]
    }
  }
}
