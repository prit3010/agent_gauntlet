{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-gauntlet.local/contracts/promotion_record.schema.json",
  "title": "Agent Gauntlet Promotion Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "promotionId",
    "createdAt",
    "promotedCandidate",
    "promotedHarnessVersion",
    "candidateHarnessVersion",
    "promotedAgentVersionPath",
    "currentVersionManifestPath",
    "patchType",
    "validationScore",
    "gatePassed",
    "decision",
    "whyPromoted",
    "status"
  ],
  "properties": {
    "promotionId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "promotedCandidate": {
      "type": "string",
      "minLength": 1
    },
    "promotedHarnessVersion": {
      "type": "string",
      "minLength": 1
    },
    "candidateHarnessVersion": {
      "type": "string",
      "minLength": 1
    },
    "promotedAgentVersionPath": {
      "type": "string",
      "minLength": 1
    },
    "currentVersionManifestPath": {
      "type": "string",
      "minLength": 1
    },
    "patchType": {
      "type": "string",
      "minLength": 1
    },
    "validationScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "gatePassed": {
      "type": "boolean"
    },
    "decision": {
      "type": "string",
      "enum": ["deterministic_gate"]
    },
    "whyPromoted": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": ["fixture_backed_interface"]
    }
  }
}
